rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // USERS — anyone signed in can read (for community/follow counts)
    // each user can write their own profile; follow updates allow followerIds changes
    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isOwner(userId);

      // Owner can update own full profile (but not unblock themselves)
      allow update: if (
          isOwner(userId)
          && (!('blocked' in request.resource.data)
              || request.resource.data.blocked == resource.data.blocked)
        )
        || (
          // Other users may only update follower list/stats when following
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['followerIds', 'stats', 'updatedAt'])
        )
        || isAdmin();

      allow delete: if isAdmin();
    }

    // COURSES
    match /courses/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // BOOKS
    match /books/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // VIDEOS
    match /videos/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // CHATS
    match /chats/{chatId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.members;

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.members;

      allow update: if signedIn()
        && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow read: if signedIn();
        // Max 32 letters/characters per message
        allow create: if signedIn()
          && request.resource.data.keys().hasAll(['chatId', 'fromUid', 'text', 'createdAt'])
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 32;
      }
    }

    // NOTIFICATIONS
    match /notifications/{id} {
      allow read: if signedIn()
        && resource.data.toUid == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid;

      allow update: if signedIn()
        && resource.data.toUid == request.auth.uid;

      allow delete: if signedIn()
        && resource.data.toUid == request.auth.uid;
    }

    // CALLS (video call ring/accept)
    match /calls/{id} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid;

      allow update: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }
  }
}
